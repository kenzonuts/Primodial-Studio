# Public site URL used for canonical links, sitemap, and Open Graph.
NEXT_PUBLIC_SITE_URL=https://primordial.studio

# CMS provider: static | payload | sanity | contentful | strapi
CMS_PROVIDER=static

# Payload
PAYLOAD_SECRET=replace-with-a-long-random-string
DATABASE_URI=file:./data/payload.db
CMS_REVALIDATE_SECONDS=60

# --- Feature flags (true/false) ---
NEXT_PUBLIC_COOKIE_CONSENT=true
NEXT_PUBLIC_ANALYTICS_VERCEL=true
NEXT_PUBLIC_ANALYTICS_SPEED_INSIGHTS=true
NEXT_PUBLIC_ANALYTICS_GA4=false
NEXT_PUBLIC_ANALYTICS_GTM=false
NEXT_PUBLIC_ANALYTICS_PLAUSIBLE=false
NEXT_PUBLIC_ANALYTICS_CLARITY=false
NEXT_PUBLIC_REPORT_WEB_VITALS=true
NEXT_PUBLIC_MONITORING_SENTRY=false
NEXT_PUBLIC_MONITORING_LOGROCKET=false

# --- Analytics IDs (enable matching flags above) ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_TWITTER_HANDLE=@primordialstudio

# --- Monitoring (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_LOGROCKET_APP_ID=
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=
